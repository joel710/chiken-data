# ============================================
# Configuration - Détection Maladies Aviaires
# ============================================
# Copiez ce fichier en .env et remplissez vos clés
#   cp .env.example .env
#
# Obtenez votre clé Roboflow gratuitement :
#   1. Créez un compte sur https://roboflow.com
#   2. Allez dans Settings > API Keys
#   3. Copiez votre clé (commence par "rf_")
# ============================================

# Clé API Roboflow (obligatoire pour télécharger les datasets)
ROBOFLOW_API_KEY="rf_xxxx..."
